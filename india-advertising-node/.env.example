# ============================================
# BACKEND CONFIGURATION (.env)
# Copy this file to .env and update values
# IMPORTANT: Never commit actual .env to git!
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
HOST=localhost

# ============================================
# ADMIN AUTHENTICATION
# ============================================
# IMPORTANT: Change this strong password in production!
# Used to verify admin dashboard access
ADMIN_PASSWORD=secure-password-change-this

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Required for sending quote & contact form emails

# Gmail Account Setup:
# 1. Enable 2-Factor Authentication (2FA)
#    → Go to https://myaccount.google.com/security
# 2. Generate App Password
#    → Go to https://myaccount.google.com/apppasswords
#    → Select "Mail" and "Windows Computer"
#    → Copy the 16-character password (remove spaces)
# 3. Paste App Password below (NOT your real Gmail password!)

GMAIL_USER=indiaadvertising05@gmail.com
GMAIL_PASS=stllwvdrvljilqhq

# Email sending addresses
GMAIL_FROM=noreply@indiaadvertising.com
GMAIL_TO=info@indiaadvertising.com
GMAIL_SUBJECT_PREFIX=[India Advertising Quote]

# ============================================
# CORS CONFIGURATION
# ============================================
# Controls which domains can access the API
# '*' allows any domain (development only!)
# Production: Use specific domain like 'https://yourdomain.com'
CORS_ORIGIN=*

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Path to company data JSON file
COMPANY_DATA_PATH=./data/companyData.json

# Directory for uploaded images
UPLOADS_DIR=./uploads

# Maximum file size for uploads (in MB)
MAX_FILE_SIZE=50

# Allowed image types
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# ============================================
# BUILD & SERVING (Optional)
# ============================================
# Serve React build from backend
SERVE_BUILD=false
BUILD_DIR=../indiaadvertising/build

# ============================================
# DATABASE CONFIGURATION (Future: PostgreSQL)
# ============================================
# Uncomment when migrating to PostgreSQL database

# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=india_advertising
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m

# ============================================
# SECURITY (For Production)
# ============================================

# JWT Configuration (for future JWT auth upgrade)
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRY=7d

# API Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Session timeout (minutes)
SESSION_TIMEOUT=60

# ============================================
# EXTERNAL SERVICES (Optional - Future)
# ============================================

# AWS S3 (for cloud image storage)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# Cloudinary (for image optimization & CDN)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# SendGrid (for better email management)
# SENDGRID_API_KEY=your-sendgrid-key

# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================
# Settings recommended for development
PORT=5000
NODE_ENV=development
ADMIN_PASSWORD=dev-password
CORS_ORIGIN=*
LOG_LEVEL=debug

# ============================================
# PRODUCTION ENVIRONMENT
# ============================================
# Settings recommended for production
# PORT=443
# NODE_ENV=production
# ADMIN_PASSWORD=very-strong-secure-password-here
# CORS_ORIGIN=https://yourdomain.com
# LOG_LEVEL=info
# SERVE_BUILD=true
# JWT_SECRET=strong-jwt-secret-key-here
# RATE_LIMIT_MAX_REQUESTS=50